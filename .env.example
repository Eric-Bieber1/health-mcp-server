# Garmin Connect
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password
GARMIN_TOKENSTORE=/app/data/.garminconnect

# Dexcom
DEXCOM_USERNAME=your_username
DEXCOM_PASSWORD=your_password
DEXCOM_REGION=us

# Glucose thresholds
GLUCOSE_LOW=70
GLUCOSE_HIGH=180

# Database
DB_PATH=/app/data/fitness.db

# Server
PORT=3000
